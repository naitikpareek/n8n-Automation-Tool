    {
      "parameters": {
        "jsCode": "let data = items.map(i => i.json);\n\n// qty ke basis par sort (high to low)\ndata.sort((a, b) => b.qty - a.qty);\n\n// rank add karna\ndata = data.map((item, index) => ({\n  ...item,\n  rank: index + 1\n}));\n\nreturn data.map(d => ({ json: d }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
