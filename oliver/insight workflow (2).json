      "parameters": {
        "actorSource": "store",
        "actorId": {
          "__rl": true,
          "value": "https://console.apify.com/actors/MpRbnNmVAoj5RC1Ma/input",
          "mode": "url"
        },
        "customBody": "={\n  \"startUrls\": [\n    {\n      \"url\": \"https://www.netcomponents.com/demo/result?SearchLogic=begins&PSA=true&PartsSearched%5B0%5D.PartNumber={{ $json.partNumber }}\"\n    }\n  ],\n  \"pageFunction\": \"async function pageFunction(context) { let { page } = context; return await page.$$eval('tr', (rows) => { let isDate = (str) => /\\\\d{2}\\\\/\\\\d{2}\\\\/\\\\d{4}/.test(str); return rows.map(row => { let cells = Array.from(row.querySelectorAll('td')); if (cells.length < 9) return null; let partText = cells[0]?.innerText.trim() || ''; if (!partText || /Europe|In-Stock|Part Number/i.test(partText)) return null; /* Description: Pehli script ka logic (isDate check ke saath) */ let qtyDataForDesc = cells[5]?.innerText.trim() || cells[6]?.innerText.trim() || ''; let descData = isDate(qtyDataForDesc) ? '' : qtyDataForDesc; /* Part, Mfr, DC: Doosri script ka logic */ let mfrData = cells[3]?.innerText.replace(/\\\\n/g, ' ').trim() || ''; let dcData = cells[4]?.innerText.trim() || ''; /* Qty: Doosri script ka logic (Strictly Cell 8) */ let rawQty = cells[8]?.innerText.trim() || '0'; let cleanQty = rawQty.replace(/[^0-9]/g, ''); let strictResult = Object.freeze({ partNumber: partText, mfr: mfrData, dc: dcData, description: descData, qty: cleanQty }); return { partNumber: strictResult.partNumber, mfr: strictResult.mfr, dc: strictResult.dc, description: strictResult.description, qty: strictResult.qty }; }).filter(r => r !== null && r.partNumber !== ''); }); }\"\n}",
        "authentication": "apifyOAuth2Api"
      },
