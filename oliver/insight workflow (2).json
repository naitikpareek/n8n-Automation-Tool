      ],
      "id": "1d81dc78-b133-4b9e-8a85-76c9964eb6bd",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const data = items.map(i => i.json);\n\n// total qty calculate\nconst totalQty = data.reduce((sum, item) => {\n  const qty = Number(item.qty) || 0;\n  return sum + qty;\n}, 0);\n\n// top item\nconst top = data[0];\n\n// lowest item\nconst lowest = data[data.length - 1];\n\nreturn [\n  {\n    json: {\n      total_parts: data.length,\n      total_quantity: totalQty,\n      top_partNumber: top.partNumber,\n      top_qty: Number(top.qty),\n      lowest_partNumber: lowest.partNumber,\n      lowest_qty: Number(lowest.qty)\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
